DATABASE_URL="postgresql://user:pass@localhost:5432/escola?schema=public"
AUTH_SECRET="troque-por-uma-string-aleatoria-longa"
# Diretório de uploads de documentos (default: ./uploads)
UPLOAD_DIR="./uploads"

# --- Integrações externas (todas opcionais; deixe em branco para usar stubs/desabilitar) ---
# Evolution API (WhatsApp self-hosted)
# EVOLUTION_API_URL="https://evolution.exemplo.com"
# EVOLUTION_API_KEY=""
# EVOLUTION_INSTANCE="principal"
# PIX (provedor de cobrança)
# PIX_PROVIDER_URL=""
# PIX_PROVIDER_KEY=""
# Assinatura eletrônica (ZapSign, Clicksign, D4Sign...)
# ASSINATURA_PROVIDER_URL=""
# ASSINATURA_PROVIDER_KEY=""
# Login com Google (opcional; habilita botão "Entrar com Google")
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# URL pública da app (usada em links de e-mail; default = origin da requisição)
# APP_URL="https://escola.exemplo.com"
# SMTP (e-mail de reset de senha e comunicados; sem isso, cai em modo log/dev)
# SMTP_HOST="smtp.exemplo.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="ERP Escola <no-reply@escola.com>"
